#!/usr/bin/env bash
# Mock docker shim for testing apply-sonar.sh
set -euo pipefail

if [[ -n "${TEST_TMPDIR:-}" ]]; then
    echo "docker $*" >> "$TEST_TMPDIR/docker_calls"
fi

case "${1:-}" in
    info)
        if [[ "${MOCK_DOCKER_AVAILABLE:-false}" = "true" ]]; then
            echo "Docker info: mock"
            exit 0
        else
            echo "Cannot connect to the Docker daemon" >&2
            exit 1
        fi
        ;;
    run)
        echo "INFO: Docker analysis complete"
        exit "${MOCK_SCANNER_EXIT:-0}"
        ;;
    *)
        exit 0
        ;;
esac
